.DS_Store
.env
node_modules/
__old

# Backup files
*.bak
*.bak.*
*~
*.orig

# Local on-save auto-commit flag (each clone keeps its own ON/OFF)
.vscode/.onsave-toggle

# Ignore everything in the temp directory, but keep the temp directory itself in source control.
/tmp/*
!/tmp/.gitkeep

# Machine-local runtime data store: track the directory, ignore its contents.
# Explicit carve-outs only for intentionally tracked docs/placeholders.
/data/*
!/data/README.md

# Cerebras training data (JSONL)
src/python/cerebras/**/*.jsonl

# Job Hunter machine-local/generated artifacts
/job-hunter/data/*
!/job-hunter/data/.gitkeep
!/job-hunter/data/quarantine/
!/job-hunter/data/quarantine/.gitkeep
!/job-hunter/data/raw/
!/job-hunter/data/raw/.gitkeep
/job-hunter/data/quarantine/*
!/job-hunter/data/quarantine/.gitkeep
/job-hunter/data/raw/*
!/job-hunter/data/raw/.gitkeep
/job-hunter/dashboard/index.html
/job-hunter/dashboard/assets/
/job-hunter/.job-hunter.lock
/job-hunter/.tmp/
